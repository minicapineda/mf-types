{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "declaration": true,
        "declarationMap": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "composite": true,
        "forceConsistentCasingInFileNames": true,
        "preserveSymlinks": false,
        "skipLibCheck": true,
        "isolatedModules": true,
        "moduleDetection": "force"
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}